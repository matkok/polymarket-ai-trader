# Database
POSTGRES_USER=agent_trader
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=agent_trader
DATABASE_URL=postgresql+asyncpg://agent_trader:devpassword@localhost:5432/agent_trader

# API Keys (LLM providers — needed for Milestone 3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Polymarket (read-only, no key needed for public APIs)
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_BASE_URL=https://clob.polymarket.com

# Signal sources (optional — disabled by default)
GOOGLE_TRENDS_ENABLED=false
GOOGLE_TRENDS_TRAILING_DAYS=30
WIKIPEDIA_ENABLED=false
WIKIPEDIA_TRAILING_DAYS=30

# Logging
LOG_LEVEL=INFO
